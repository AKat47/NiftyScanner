{
  "rewrites": [
    { "source": "/api/kite/:path*", "destination": "/api/proxy.js" },
    { "source": "/api/angel",       "destination": "/api/angel.js" },
    { "source": "/api/yahoo",       "destination": "/api/yahoo.js" },
    { "source": "/api/candles",     "destination": "/api/candles.js" },
    { "source": "/api/scan",        "destination": "/api/scan.js" },
    { "source": "/api/quote",       "destination": "/api/quote.js" },
    { "source": "/api/intraday",    "destination": "/api/intraday.js" },
    { "source": "/api/notify",      "destination": "/api/notify.js" },
    { "source": "/api/portfolio",   "destination": "/api/portfolio.js" },
    { "source": "/api/cron-scan",   "destination": "/api/cron-scan.js" }
  ],
  "crons": [
    {
      "path":     "/api/cron-scan",
      "schedule": "* 3-10 * * 1-5"
    }
  ]
}
